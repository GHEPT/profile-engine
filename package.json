{
    "name": "profile-engine",
    "version": "2.0.0",
    "description": "Static engine that generates beautiful GitHub profile READMEs from structured YAML content.",
    "author": "Eduardo Teodoro",
    "license": "MIT",
    "private": true,
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsup src/index.ts --format esm --clean",
        "start": "node dist/index.js",
        "generate": "tsx src/index.ts",
        "lint": "eslint .",
        "format": "prettier --write .",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "gray-matter": "^4.0.3",
        "js-yaml": "^4.1.0",
        "sharp": "^0.34.3"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^24.0.15",
        "eslint": "^9.30.1",
        "prettier": "^3.6.2",
        "tsup": "^8.5.0",
        "tsx": "^4.20.3",
        "typescript": "^5.8.3"
    },
    "engines": {
        "node": ">=22"
    }
}